# DDR AI System — Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (optional — system works offline without it)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# Default Gemini model (options: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash)
GEMINI_MODEL=gemini-1.5-pro

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
